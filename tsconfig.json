{
  "files": [],
  "include": [],
  "references": [{ "path": "./server" }, { "path": "./client" }],
  "compilerOptions": {
    "target": "ES2020",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@server/*": ["./server/src/*"],
      "@client/*": ["./client/src/*"]
    }
  }
}
